# ---------------------------------------------------------------------------
# RustDesk Address Companion — environment configuration
# Copy this file to `.env` and edit as needed.
# ---------------------------------------------------------------------------

# Host path to your RustDesk OSS server data directory (where hbbs writes
# db_v2.sqlite3 and the public/private keys). Mounted READ-ONLY.
# Examples:
#   /var/lib/rustdesk-server
#   C:\rustdesk-server\data
RUSTDESK_HOST_DATA_DIR=./rustdesk-data

# RustDesk database filename inside that directory. Override if your RustDesk
# installation uses a different name.
RUSTDESK_DB_FILENAME=db_v2.sqlite3

# How often the background sync runs (seconds).
SYNC_INTERVAL_SECONDS=60

# Feature flag: expose a "Launch RustDesk" button in the UI that attempts
# `rustdesk://<id>`. Disabled by default; browser-to-local-app launching
# is highly environment-dependent.
LAUNCH_RUSTDESK_ENABLED=false

# Host port for the web UI (nginx).
FRONTEND_PORT=8080

# Internal container paths — rarely need changing.
APP_DB_PATH=/data/companion.sqlite3
RUSTDESK_DATA_DIR=/rustdesk-data

# CORS origins for the backend API (comma-separated). In the default compose
# setup, the frontend and backend share an origin via the nginx reverse proxy,
# so this does not normally matter.
CORS_ALLOW_ORIGINS=*

# ---------------------------------------------------------------------------
# Live presence (green/gray dots in the UI)
# ---------------------------------------------------------------------------
# The companion queries hbbs's in-memory peer registry via RustDesk's
# rendezvous protocol on the NAT-test TCP port (= main port - 1, default 21115).
# On Linux Docker we resolve host.docker.internal via extra_hosts in compose.
# Set HBBS_HOST to an empty string to disable presence polling entirely.
HBBS_HOST=host.docker.internal
HBBS_PORT=21115
PRESENCE_INTERVAL_SECONDS=20
PRESENCE_TIMEOUT_SECONDS=5.0
